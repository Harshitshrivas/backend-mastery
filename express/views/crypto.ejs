    <script>
        document.addEventListener('DOMContentLoaded', function() {
    // Initialize all functionality
    initPriceTicker();
    initTradingForms();
    initChart();
    initAnimations();
    initScrollEffects();
    initCounters();
});

// Live Price Ticker
function initPriceTicker() {
    // Simulate live price updates
    const prices = {
        btc: 45234.56,
        eth: 2845.12,
        ltc: 145.67
    };
    
    // Update prices every 3 seconds
    setInterval(() => {
        // Simulate price changes
        prices.btc += (Math.random() - 0.5) * 100;
        prices.eth += (Math.random() - 0.5) * 10;
        prices.ltc += (Math.random() - 0.5) * 2;
        
        // Update DOM
        document.getElementById('btc-price').textContent = prices.btc.toFixed(2);
        document.getElementById('eth-price').textContent = prices.eth.toFixed(2);
        document.getElementById('ltc-price').textContent = prices.ltc.toFixed(2);
        
        // Update price change indicators
        updatePriceChanges();
        
        // Update trading form prices
        updateTradingPrices(prices.btc);
    }, 3000);
}

// Update price change indicators
function updatePriceChanges() {
    const changes = document.querySelectorAll('.price-change');
    changes.forEach(change => {
        const isPositive = Math.random() > 0.3;
        change.className = `price-change ${isPositive ? 'positive' : 'negative'}`;
        change.textContent = `${isPositive ? '+' : '-'}${(Math.random() * 5).toFixed(2)}%`;
    });
}

// Update trading prices
function updateTradingPrices(btcPrice) {
    const pricePerBtc = document.getElementById('pricePerBtc');
    if (pricePerBtc) {
        pricePerBtc.textContent = `$${btcPrice.toFixed(2)}`;
    }
    
    // Recalculate if user has entered amount
    const buyAmount = document.getElementById('buyAmount');
    if (buyAmount && buyAmount.value) {
        calculateBtcAmount();
    }
}

// Trading Forms
function initTradingForms() {
    // Buy form
    const buyForm = document.getElementById('buyForm');
    if (buyForm) {
        buyForm.addEventListener('submit', handleBuySubmit);
    }
    
    // Sell form
    const sellForm = document.getElementById('sellForm');
    if (sellForm) {
        sellForm.addEventListener('submit', handleSellSubmit);
    }
    
    // Amount input listeners
    const buyAmount = document.getElementById('buyAmount');
    if (buyAmount) {
        buyAmount.addEventListener('input', calculateBtcAmount);
    }
    
    const sellBtcAmount = document.getElementById('sellBtcAmount');
    if (sellBtcAmount) {
        sellBtcAmount.addEventListener('input', calculateUsdAmount);
    }
}

// Calculate Bitcoin amount from USD
function calculateBtcAmount() {
    const usdAmount = parseFloat(document.getElementById('buyAmount').value) || 0;
    const btcPrice = parseFloat(document.getElementById('btc-price').textContent.replace(',', ''));
    const btcAmount = usdAmount / btcPrice;
    
    document.getElementById('btcAmount').value = btcAmount.toFixed(8);
    document.getElementById('totalAmount').textContent = `$${usdAmount.toFixed(2)}`;
}

// Calculate USD amount from Bitcoin
function calculateUsdAmount() {
    const btcAmount = parseFloat(document.getElementById('sellBtcAmount').value) || 0;
    const btcPrice = parseFloat(document.getElementById('btc-price').textContent.replace(',', ''));
    const usdAmount = btcAmount * btcPrice;
    
    document.getElementById('sellUsdAmount').value = usdAmount.toFixed(2);
}

// Set quick amount
function setAmount(amount) {
    document.getElementById('buyAmount').value = amount;
    calculateBtcAmount();
}

// Handle buy submission
function handleBuySubmit(e) {
    e.preventDefault();
    
    const buyAmount = document.getElementById('buyAmount').value;
    const btcAmount = document.getElementById('btcAmount').value;
    
    // Show loading state
    const submitBtn = e.target.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<span class="loading"></span> Processing...';
    submitBtn.disabled = true;
    
    // Simulate transaction
    setTimeout(() => {
        showTransactionMessage('success', `Successfully purchased ${btcAmount} BTC for $${buyAmount}!`);
        e.target.reset();
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
        
        // Update user balance (simulation)
        updateUserBalance(parseFloat(btcAmount));
    }, 2000);
}

// Handle sell submission
function handleSellSubmit(e) {
    e.preventDefault();
    
    const btcAmount = document.getElementById('sellBtcAmount').value;
    const usdAmount = document.getElementById('sellUsdAmount').value;
    
    // Show loading state
    const submitBtn = e.target.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<span class="loading"></span> Processing...';
    submitBtn.disabled = true;
    
    // Simulate transaction
    setTimeout(() => {
        showTransactionMessage('success', `Successfully sold ${btcAmount} BTC for $${usdAmount}!`);
        e.target.reset();
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
        
        // Update user balance (simulation)
        updateUserBalance(-parseFloat(btcAmount));
    }, 2000);
}

// Show transaction message
function showTransactionMessage(type, message) {
    // Create message element
    const messageDiv = document.createElement('div');
    messageDiv.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed`;
    messageDiv.style.cssText = 'top: 100px; right: 20px; z-index: 9999; min-width: 300px;';
    messageDiv.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    
    document.body.appendChild(messageDiv);
    
    // Auto remove after 5 seconds
    setTimeout(() => {
        messageDiv.remove();
    }, 5000);
}

// Update user balance (simulation)
function updateUserBalance(change) {
    // This would typically update from a backend
    console.log(`Balance updated by ${change} BTC`);
}

// Initialize Chart
function initChart() {
    const ctx = document.getElementById('priceChart');
    if (!ctx) return;
    
    // Generate sample data
    const labels = [];
    const data = [];
    const currentPrice = 45234.56;
    
    for (let i = 30; i >= 0; i--) {
        labels.push(`-${i}d`);
        data.push(currentPrice + (Math.random() - 0.5) * 2000);
    }
    
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Bitcoin Price (USD)',
                data: data,
                borderColor: '#f7931a',
                backgroundColor: 'rgba(247, 147, 26, 0.1)',
                borderWidth: 3,
                fill: true,
                tension: 0.4,
                pointRadius: 0,
                pointHoverRadius: 6,
                pointBackgroundColor: '#f7931a'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    mode: 'index',
                    intersect: false,
                    backgroundColor: 'rgba(0, 0, 0, 0.8)',
                    titleColor: '#f7931a',
                    bodyColor: '#fff',
                    borderColor: '#f7931a',
                    borderWidth: 1,
                    padding: 12,
                    displayColors: false,
                    callbacks: {
                        label: function(context) {
                            return `Price: $${context.parsed.y.toFixed(2)}`;
                        }
                    }
                }
            },
            scales: {
                x: {
                    display: false
                },
                y: {
                    display: false
                }
            },
            interaction: {
                mode: 'nearest',
                axis: 'x',
                intersect: false
            }
        }
    });
}

// Animations
function initAnimations() {
    // Intersection Observer for scroll animations
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -100px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('animate-fade-in');
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
            }
        });
    }, observerOptions);
    
    // Observe elements
    const animateElements = document.querySelectorAll('.feature-card, .pricing-card, .testimonial-card');
    animateElements.forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(30px)';
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        observer.observe(el);
    });
}

// Scroll Effects
function initScrollEffects() {
    // Navbar background on scroll
    const navbar = document.querySelector('.navbar');
    
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            navbar.style.background = 'rgba(26, 26, 26, 0.98)';
            navbar.style.backdropFilter = 'blur(15px)';
        } else {
            navbar.style.background = 'rgba(26, 26, 26, 0.95)';
            navbar.style.backdropFilter = 'blur(10px)';
        }
    });
    
    // Smooth scrolling for navigation links
    const navLinks = document.querySelectorAll('.nav-link[href^="#"]');
    navLinks.forEach(link => {
        link.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = link.getAttribute('href').substring(1);
            const targetSection = document.getElementById(targetId);
            
            if (targetSection) {
                const offsetTop = targetSection.offsetTop - 80;
                window.scrollTo({
                    top: offsetTop,
                    behavior: 'smooth'
                });
                
                // Close mobile menu
                const navbarCollapse = document.querySelector('.navbar-collapse');
                if (navbarCollapse.classList.contains('show')) {
                    navbarCollapse.classList.remove('show');
                }
            }
        });
    });
}

// Counters Animation
function initCounters() {
    const counters = [
        { id: 'trading-volume', end: 2.5, suffix: 'B+', prefix: '$' },
        { id: 'active-users', end: 500, suffix: 'K+', prefix: '' },
        { id: 'uptime', end: 99.9, suffix: '%', prefix: '' }
    ];
    
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting && !entry.target.classList.contains('counted')) {
                entry.target.classList.add('counted');
                const counter = counters.find(c => entry.target.textContent.includes(c.suffix));
                if (counter) {
                    animateCounter(entry.target, counter.end, counter.suffix, counter.prefix);
                }
            }
        });
    }, { threshold: 0.5 });
    
    // Observe stat elements
    document.querySelectorAll('.stat-box h3, .cta-stats h3').forEach(el => {
        counterObserver.observe(el);
    });
}

// Animate counter
function animateCounter(element, end, suffix, prefix) {
    let current = 0;
    const increment = end / 100;
    const timer = setInterval(() => {
        current += increment;
        if (current >= end) {
            current = end;
            clearInterval(timer);
        }
        element.textContent = prefix + current.toFixed(end < 100 ? 1 : 0) + suffix;
    }, 20);
}

// Scroll to section
function scrollToSection(sectionId) {
    const section = document.getElementById(sectionId);
    if (section) {
        const offsetTop = section.offsetTop - 80;
        window.scrollTo({
            top: offsetTop,
            behavior: 'smooth'
        });
    }
}

