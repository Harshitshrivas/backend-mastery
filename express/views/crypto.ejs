<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryptoTrade Pro - Buy & Sell Bitcoin Instantly</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* Bitcoin Trading Landing Page Styles */

:root {
    --bitcoin-orange: #f7931a;
    --bitcoin-dark: #4a4a4a;
    --success-green: #00d4aa;
    --danger-red: #ff4444;
    --dark-bg: #1a1a1a;
    --card-bg: #ffffff;
    --text-primary: #2c3e50;
    --text-secondary: #6c757d;
    --border-color: #e9ecef;
}

/* Global Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    line-height: 1.6;
    color: var(--text-primary);
    overflow-x: hidden;
}

/* Navigation */
.navbar {
    background: rgba(26, 26, 26, 0.95) !important;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
}

.navbar-brand {
    font-weight: bold;
    font-size: 1.5rem;
}

.nav-link {
    transition: color 0.3s ease;
}

.nav-link:hover {
    color: var(--bitcoin-orange) !important;
}

/* Price Ticker */
.price-ticker {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
}

.ticker-wrapper {
    display: flex;
    justify-content: space-around;
    align-items: center;
    font-family: 'Courier New', monospace;
}

.ticker-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
}

.price-change.positive {
    color: var(--success-green);
}

.price-change.negative {
    color: var(--danger-red);
}

/* Hero Section */
.hero-section {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d3748 100%);
    position: relative;
    overflow: hidden;
}

.hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23f7931a" fill-opacity="0.1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,138.7C960,139,1056,117,1152,101.3C1248,85,1344,75,1392,69.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
    background-size: cover;
    opacity: 0.3;
}

.stat-box {
    text-align: center;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    backdrop-filter: blur(10px);
}

.hero-buttons {
    margin: 2rem 0;
}

.trust-badges {
    margin-top: 2rem;
}

/* Bitcoin Animation */
.bitcoin-animation {
    position: relative;
    text-align: center;
    margin-bottom: 2rem;
}

.bitcoin-animation i {
    font-size: 4rem;
    color: var(--bitcoin-orange);
    animation: float 3s ease-in-out infinite;
    text-shadow: 0 0 30px rgba(247, 147, 26, 0.5);
}

@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
}

/* Chart Container */
.chart-container {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 15px;
    padding: 2rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
}

/* Trade Card */
.trade-card {
    border: none;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    margin-top: -100px;
    position: relative;
    z-index: 10;
}

.trade-card .card-header {
    border: none;
    padding: 1.5rem;
}

.trade-card .card-body {
    padding: 2rem;
}

.nav-pills .nav-link {
    border-radius: 10px;
    padding: 0.75rem 1.5rem;
    margin-right: 0.5rem;
}

.nav-pills .nav-link.active {
    background: var(--bitcoin-orange);
}

.quick-amounts {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.fee-info {
    border-radius: 10px;
    margin-top: 1rem;
}

.wallet-info {
    border-radius: 10px;
}

/* Feature Cards */
.feature-card {
    text-align: center;
    padding: 2rem;
    background: white;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    height: 100%;
    border: none;
}

.feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.feature-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    background: linear-gradient(135deg, var(--bitcoin-orange), #ff8c00);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: white;
    box-shadow: 0 10px 20px rgba(247, 147, 26, 0.3);
}

/* Pricing Cards */
.pricing-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    position: relative;
    border: 2px solid transparent;
}

.pricing-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.pricing-card.popular {
    border-color: var(--bitcoin-orange);
    transform: scale(1.05);
}

.pricing-badge {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bitcoin-orange);
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: bold;
}

.pricing-header h3 {
    color: var(--text-primary);
    margin-bottom: 1rem;
}

.price {
    margin: 1.5rem 0;
}

.price .currency {
    font-size: 1.5rem;
    color: var(--text-secondary);
}

.price .amount {
    font-size: 3.5rem;
    font-weight: bold;
    color: var(--bitcoin-orange);
}

.price .period {
    color: var(--text-secondary);
    font-size: 1rem;
}

.pricing-features {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
    text-align: left;
}

.pricing-features li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
}

.pricing-features li i {
    margin-right: 0.75rem;
    width: 20px;
}

/* Testimonial Cards */
.testimonial-card {
    background: white;
    border-radius: 15px;
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    height: 100%;
}

.testimonial-stars {
    margin-bottom: 1rem;
    color: var(--bitcoin-orange);
}

.testimonial-text {
    font-style: italic;
    margin-bottom: 1.5rem;
    line-height: 1.6;
}

.testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.testimonial-author img {
    width: 50px;
    height: 50px;
    object-fit: cover;
}

/* CTA Section */
.cta-stats h3 {
    font-size: 2rem;
    font-weight: bold;
}

.cta-stats small {
    color: rgba(255, 255, 255, 0.7);
}

/* Footer */
footer {
    background: #000 !important;
}

footer a {
    text-decoration: none;
    transition: color 0.3s ease;
}

footer a:hover {
    color: var(--bitcoin-orange) !important;
}

.social-links a {
    font-size: 1.5rem;
    transition: all 0.3s ease;
}

.social-links a:hover {
    color: var(--bitcoin-orange) !important;
    transform: translateY(-3px);
}

/* Form Styles */
.form-control {
    border-radius: 10px;
    border: 2px solid var(--border-color);
    padding: 0.75rem;
    transition: all 0.3s ease;
}

.form-control:focus {
    border-color: var(--bitcoin-orange);
    box-shadow: 0 0 0 0.2rem rgba(247, 147, 26, 0.25);
}

.input-group-text {
    background: var(--light-gray);
    border: 2px solid var(--border-color);
    border-radius: 10px;
}

/* Button Styles */
.btn {
    border-radius: 50px;
    padding: 0.75rem 2rem;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
}

.btn-lg {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
}

.btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
}

.btn-warning {
    background: var(--bitcoin-orange);
}

.btn-warning:hover {
    background: #e8850f;
}

/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.animate-fade-in {
    animation: fadeInUp 0.6s ease-out;
}

/* Responsive Design */
@media (max-width: 768px) {
    .hero-section h1 {
        font-size: 2.5rem;
    }
    
    .trade-card {
        margin-top: -50px;
        margin: 20px;
    }
    
    .pricing-card.popular {
        transform: scale(1);
    }
    
    .ticker-wrapper {
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .ticker-item {
        font-size: 0.8rem;
    }
    
    .stat-box {
        margin-bottom: 0.5rem;
    }
    
    .quick-amounts {
        justify-content: center;
    }
}

/* Loading Animation */
.loading {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: #fff;
    animation: spin 1s ease-in-out infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Success/Error Messages */
.alert-custom {
    border-radius: 10px;
    padding: 1rem;
    margin-top: 1rem;
    display: none;
}

.alert-custom.success {
    background: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
}

.alert-custom.error {
    background: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
}

/* Scroll Effects */
html {
    scroll-behavior: smooth;
}

/* Custom Scrollbar */
::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-track {
    background: #f1f1f1;
}

::-webkit-scrollbar-thumb {
    background: var(--bitcoin-orange);
    border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
    background: #e8850f;
}

/* Additional utility classes */
.text-orange {
    color: var(--bitcoin-orange) !important;
}

.bg-orange {
    background-color: var(--bitcoin-orange) !important;
}

.border-orange {
    border-color: var(--bitcoin-orange) !important;
}
    </style>
</head>
